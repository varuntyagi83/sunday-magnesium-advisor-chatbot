# ─────────────────────────────────────────────────────────────
# Required — Gemini API (single LLM provider for all agents)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy-xxxxx
GEMINI_MODEL_FAST=gemini-2.5-flash        # intent classification (fast, cheap, structured JSON)
GEMINI_MODEL_REASONING=gemini-2.5-pro     # health profiler, safety, dosage, composer, follow-ups

# ─────────────────────────────────────────────────────────────
# Required — Custom MCP Endpoint (Sunday Natural's own DB)
# NOT Supabase MCP. NOT n8n MCP. Sunday Natural's custom endpoint.
# ─────────────────────────────────────────────────────────────
MCP_ENDPOINT_URL=https://your-mcp-endpoint.sundaynatural.internal/v1
MCP_AUTH_TOKEN=your-bearer-token
MCP_TRANSPORT=http                        # "http" or "sse"

# ─────────────────────────────────────────────────────────────
# Embeddings — chatbot READS pre-computed embeddings only
# Does NOT generate product embeddings. Generates ONE query
# embedding per user message for semantic similarity matching.
# EMBEDDING_MODEL must match whatever your pipeline used.
# ─────────────────────────────────────────────────────────────
EMBEDDINGS_SOURCE=mcp                     # "mcp", "api", or "bigquery"
EMBEDDINGS_API_URL=                       # only if EMBEDDINGS_SOURCE=api
EMBEDDING_MODEL=text-embedding-004        # MUST match your pipeline's model
EMBEDDINGS_REFRESH_INTERVAL_MIN=30        # re-fetch product embeddings every N minutes
OPENAI_API_KEY=sk-xxxxx                   # only if your pipeline uses OpenAI embeddings

# ─────────────────────────────────────────────────────────────
# Optional — Analytics (BigQuery)
# ─────────────────────────────────────────────────────────────
BIGQUERY_PROJECT_ID=sundaynatural-data
BIGQUERY_DATASET=advisor_analytics

# ─────────────────────────────────────────────────────────────
# Optional — Caching
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug
RATE_LIMIT_RPM=10
